[00:00:08.083] Server  LOG     Contentful fields: "{\n  \"name\": \"The Aha Moment\",\n  \"slug\": \"the-aha-moment\",\n  \"author\": \"David Kuria\",\n  \"category\": \"Software\",\n  \"copy\": {\n    \"nodeType\": \"document\",\n    \"data\": {},\n    \"content\": [\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"I was chatting with Izzo today and it hit me: Roundi isn’t about logistics, \",\n            \"marks\": [],\n            \"data\": {}\n          },\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"it’s about customer experience.\",\n            \"marks\": [\n              {\n                \"type\": \"bold\"\n              }\n            ],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"Customers don’t just buy products—they fuel businesses forward when they feel like they own the brand.\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"That happens in two ways:\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"unordered-list\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"list-item\",\n            \"data\": {},\n            \"content\": [\n              {\n                \"nodeType\": \"paragraph\",\n                \"data\": {},\n                \"content\": [\n                  {\n                    \"nodeType\": \"text\",\n                    \"value\": \"A story that connects.\",\n                    \"marks\": [],\n                    \"data\": {}\n                  }\n                ]\n              }\n            ]\n          },\n          {\n            \"nodeType\": \"list-item\",\n            \"data\": {},\n            \"content\": [\n              {\n                \"nodeType\": \"paragraph\",\n                \"data\": {},\n                \"content\": [\n                  {\n                    \"nodeType\": \"text\",\n                    \"value\": \"An experience that makes them proud to come back.\",\n                    \"marks\": [],\n                    \"data\": {}\n                  }\n                ]\n              }\n            ]\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"The story is up to the business.\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"The experience? That’s where Roundi helps.\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"Businesses can train their riders and drivers, then Roundi provides the tools that help them deliver that experience consistently—through smarter order allocation, visibility, and accountability.\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"So while you focus on building a great product and telling your story, Roundi makes sure the final mile feels like part of the brand. And when customers feel that, they don’t just buy again—they carry the brand forward.\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      },\n      {\n        \"nodeType\": \"paragraph\",\n        \"data\": {},\n        \"content\": [\n          {\n            \"nodeType\": \"text\",\n            \"value\": \"We’re also inviting businesses to share their stories. DM on Instagram or email \",\n            \"marks\": [],\n            \"data\": {}\n          },\n          {\n            \"nodeType\": \"hyperlink\",\n            \"data\": {\n              \"uri\": \"http://stories@roundi.africa/\"\n            },\n            \"content\": [\n              {\n                \"nodeType\": \"text\",\n                \"value\": \"stories@roundi.africa\",\n                \"marks\": [],\n                \"data\": {}\n              }\n            ]\n          },\n          {\n            \"nodeType\": \"text\",\n            \"value\": \" to get featured and access a free trial of the platform.\",\n            \"marks\": [],\n            \"data\": {}\n          }\n        ]\n      }\n    ]\n  }\n}"
