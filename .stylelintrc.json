{
  "extends": "stylelint-config-recommended",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "custom-variant",
          "theme",
          "apply",
          "import",
          "tailwind",
          "layer",
          "screen"
        ]
      }
    ]
  }
}
